# Copy to backend/.env and fill in. All keys are OPTIONAL — the platform runs
# fine on the deterministic rule engines without any of them.

# Gemini AI augmentation (scam reasoning + reel scripts)
GEMINI_API_KEY=your_google_ai_studio_key_here
# API-key ROTATION: add extra keys to survive per-key quota / rate limits.
# The client automatically rotates to the next working key on a 429/quota error.
# Use numbered slots …
# GEMINI_API_KEY_2=second_key_here
# GEMINI_API_KEY_3=third_key_here
# … or a comma-separated bundle (both forms are merged & de-duplicated):
# GEMINI_API_KEYS=keyA,keyB,keyC
# Optional — defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Pexels — higher-quality stock visuals for the Awareness-Reel agent.
# If unset, the agent falls back to Openverse (free, no key). Get one at
# https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Awareness-reel cron (opt-in). Set to 1 to auto-generate on a schedule.
# ENABLE_AUTOMATION_CRON=0
# AUTOMATION_CRON=0 8 * * *          # crontab syntax (default: daily 08:00)

# YouTube auto-publish (optional, local render only). One-time OAuth:
#   python -m app.youtube_upload      (needs client_secret.json in backend/)
# Then set:
# ENABLE_YOUTUBE_UPLOAD=1
# YOUTUBE_CLIENT_SECRET=client_secret.json

# REST API keys (partners). Defaults exist for the demo; set your own for prod.
# AUTOMATION_API_KEYS=key1,key2
# PARTNER_API_KEYS=key1,key2

# CORS — comma-separated allowed origins (defaults to *)
# CORS_ORIGINS=https://your-frontend.vercel.app

# Telegram Fraud Shield bot.
#   Local dev  → run `python -m app.telegram_bot` (long polling).
#   Deployed   → just set the token; on startup the API registers a webhook at
#                <public-url>/api/telegram/webhook and the bot works server-side.
# TELEGRAM_BOT_TOKEN=123456:ABC-your-botfather-token
# Base URL for the webhook. On Render, RENDER_EXTERNAL_URL is auto-provided;
# elsewhere set this to your public HTTPS backend URL.
# TELEGRAM_WEBHOOK_URL=https://your-backend.onrender.com
# Optional shared secret Telegram echoes back (X-Telegram-Bot-Api-Secret-Token).
# TELEGRAM_WEBHOOK_SECRET=some-random-string
# Set to 0 to disable the webhook even when a token is present.
# ENABLE_TELEGRAM_WEBHOOK=1

# Citizen Fraud Shield — WhatsApp (FREE Twilio Sandbox) + IVR (voice). No keys
# needed in this backend: Twilio just POSTs to our webhooks and we reply with TwiML.
#   WhatsApp: Twilio Console > Messaging > Try WhatsApp > sandbox 'When a message
#             comes in' webhook  ->  <public-url>/api/whatsapp/twilio  (POST)
#   IVR:      point a Twilio/Exotel number's voice webhook  ->  <public-url>/api/ivr/welcome
# Optional — shown on the Fraud Shield "try it" card (purely cosmetic):
# WHATSAPP_SANDBOX_NUMBER=+1 415 523 8886     # Twilio's shared sandbox number
# WHATSAPP_SANDBOX_CODE=your-join-code        # the unique code from your sandbox
# IVR_NUMBER=+91XXXXXXXXXX                     # your connected voice number
